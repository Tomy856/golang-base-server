{
  "name": "Go Dev Container",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/server",
  "customizations": {
    "vscode": {
      "extensions": ["golang.Go"]
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.25" 
    }
  },
  "forwardPorts": [8080, 6060],
  // これで @latest が通るようになります
  "postCreateCommand": "go install github.com/air-verse/air@latest && go install golang.org/x/tools/cmd/godoc@latest"
}