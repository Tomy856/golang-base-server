# ============================================================
# golang-base-server 環境変数設定例
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# Node.js AIプロキシのURL（Goサーバーからの接続先）
# Docker Compose内では "http://localhost:3000" でOK（同一コンテナ内）
NODE_PROXY_URL=http://localhost:3000

# AIプロバイダー切り替え: mock / gemini / bedrock
AI_PROVIDER=mock

# --- Gemini を使う場合 ---
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here

# --- AWS Bedrock を使う場合 ---
# AI_PROVIDER=bedrock
# AWS_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
