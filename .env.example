# ============================================================
# golang-base-server 環境変数設定例
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# Node.js AIプロキシのURL（Goサーバーからの接続先）
# Docker Compose内では "http://localhost:3000" でOK（同一コンテナ内）
NODE_PROXY_URL=http://localhost:3000

# AIプロバイダー切り替え: mock / gemini / bedrock
AI_PROVIDER=mock

# --- Gemini を使う場合 ---
# AI_PROVIDER=gemini
# GEMINI_API_KEY は .env には書かず .bashrc で管理する
# Ubuntu の .bashrc に以下を記載:
# export AI_KEY=your_gemini_api_key_here

# --- 社内プロキシ環境の場合 ---
# docker-compose.yml が Ubuntu の .bashrc から自動引き継ぎするため通常は不要
# コンテナ内で明示的に上書きしたい場合のみ設定
# HTTPS_PROXY=http://proxy.example.com:8080
# HTTP_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# --- AWS Bedrock を使う場合 ---
# AI_PROVIDER=bedrock
# AWS_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
